source "$PROJECT_DIR/lib/techniques/martingala.sh"

trap ctrl_c INT # Cotrol del flujo cuando aprietan ctrl + c para interrumpir el programa

# Banner de presentacion
presentation 

# Decidimos que tecnica vamos a usar:
if [[ "$technique" == "martingala" ]];then
    martingala "$money"
fi